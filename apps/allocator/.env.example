# Access gate (required in prod; middleware fails closed without it)
APP_PASSWORD=

# Vercel cron / manual sync auth
CRON_SECRET=

# Postgres (Neon via Vercel Marketplace on the warriors-allocator project)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Claude — brief assembly
ANTHROPIC_API_KEY=

# Google OAuth ("Warriors Local" client; register the allocator callback URLs)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Granola public API key (starts with grn_)
GRANOLA_API_KEY=

# Base URL for OAuth callbacks — no trailing slash
NEXT_PUBLIC_APP_URL=http://localhost:5821

# The reader's timezone; "tomorrow" and the 5am cron target are computed in this zone
APP_TIMEZONE=America/New_York

# The name on the morning greeting (build-time; redeploy after changing)
NEXT_PUBLIC_READER_NAME=
