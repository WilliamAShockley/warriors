generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// Singleton reader preferences — the app is prepared for one reader.
model ReaderSetting {
  id        String   @id @default("singleton")
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Singleton Google OAuth token, mirroring apps/web's GmailToken pattern.
model GoogleToken {
  id           String   @id @default("singleton")
  accessToken  String
  refreshToken String
  expiryDate   Float
  email        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CalendarEvent {
  id          String        @id // Google event id; recurring instances are unique with singleEvents=true
  title       String
  start       DateTime
  end         DateTime
  allDay      Boolean       @default(false)
  location    String?
  attendees   String? // JSON string [{name,email}]
  description String?
  source      String        @default("google")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  notes       MeetingNote[]

  @@index([start])
}

model MeetingNote {
  id                 String         @id // Granola note id (not_…)
  title              String
  summary            String
  attendees          String? // JSON string [{name,email}]
  calendarEventTitle String?
  calendarEventStart DateTime?
  noteUrl            String?
  raw                String? // full API payload
  granolaCreatedAt   DateTime?
  linkedEventId      String?
  linkedEvent        CalendarEvent? @relation(fields: [linkedEventId], references: [id])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([granolaCreatedAt])
}

model Todo {
  id        String    @id @default(cuid())
  text      String
  meta      String
  href      String?
  group     String
  status    String    @default("open") // open | cleared (today, undoable) | done (filed at end of day)
  clearedAt DateTime?
  // Agent-assigned categorization — infrastructure only, never rendered in the UI.
  tag       String?
  taggedBy  String?
  taggedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
}

// The Proofs: work drafted on the reader's behalf, awaiting signature.
// Reviewed strictly one at a time; approval executes the attached action.
model ReviewItem {
  id              String    @id @default(cuid())
  kind            String // email | post | analysis
  title           String
  summary         String? // one-line dek — who it's for, why it exists
  body            String // the draft itself, plain text with \n\n paragraphs
  actionType      String? // send_email | none — what approval executes
  actionJson      String? // e.g. {"to","subject","threadId"} for send_email
  sourceUrl       String? // link out when the working file lives elsewhere
  todoId          String? // the Docket item that spawned it, if any
  // Continual learning: the research context the draft was grounded in
  // (for highlight-to-provenance), and the reader's commentary on the
  // output (distilled into standing lessons for future drafts).
  grounding       String?
  commentary      String?
  // Straight-through processing: the draft as originally staged (snapshotted
  // on first amendment; null means never edited), whether it was amended,
  // and — set at signing — whether it went through untouched.
  originalBody    String?
  amended         Boolean   @default(false)
  straightThrough Boolean?
  // Audience routing and drafting mode, set at staging: exemplar retrieval
  // and the ledger segment on these so playbooks never cross-contaminate.
  audience        String? // founder | investor | other
  mode            String? // cold | follow_up
  // The sent artifact, for reply tracking — only these exact threads are
  // ever checked, never the mailbox at large.
  sentMessageId   String?
  sentThreadId    String?
  replyStatus     String? // awaiting | replied
  replyCheckedAt  DateTime?
  status          String    @default("pending") // pending | approved | spiked
  queuedAt        DateTime  @default(now()) // queue order; Hold moves it to the back
  reviewedAt      DateTime?
  executionResult String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, queuedAt])
}

model ApolloTask {
  id           String    @id @default(cuid())
  ask          String
  status       String    @default("received") // received | working | done | failed
  planNote     String? // Apollo's one-line reading of the task
  stepsJson    String    @default("[]")
  resultJson   String? // briefing shape {title, dateline, sections[]}
  traceJson    String? // full messages array — the fine-tuning dataset
  model        String
  verdict      String? // good | needs-work
  feedbackNote String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([createdAt])
}

// A reader-editable Apollo skill: the system prompt that governs a specialized
// drafting playbook (e.g. founder-email). Keyed by skill id; absence means the
// code default is in force. Edited from the Colophon (settings).
model ApolloSkill {
  id           String   @id // skill id, e.g. "founder-email"
  systemPrompt String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Continual learning, prompt-side: distilled from reader feedback,
// injected into future Apollo system prompts.
model ApolloLesson {
  id        String   @id @default(cuid())
  taskId    String
  lesson    String
  createdAt DateTime @default(now())
}

// One row per local date — the daily job upserts, so re-runs are idempotent.
model BriefEdition {
  date         String   @id // YYYY-MM-DD in APP_TIMEZONE
  leadJson     String
  itemsJson    String
  scheduleJson String
  recallJson   String? // Worth Reciting cues drawn from yesterday's Margin
  generatedAt  DateTime @default(now())
}

// Freeform thinking filed below the news wire; the desk replies inline.
model MarginEntry {
  id        String   @id @default(cuid())
  text      String
  reply     String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// A reader-defined research theme, born from the intake interview.
model ResearchThesis {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  chip      String
  stance    String
  summary   String // paragraphs joined by \n\n
  charter   String // the built research prompt
  status    String   @default("active") // active | retired
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A thought filed to The File (/notes). First line is the title.
model FiledNote {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model BookContact {
  id           String   @id @default(cuid())
  name         String
  role         String
  firm         String
  segment      String // LPs | Founders | Co-investors | Advisors
  context      String
  relationship String?
  followUp     String?
  location     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
