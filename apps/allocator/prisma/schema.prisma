generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// Singleton reader preferences — the app is prepared for one reader.
model ReaderSetting {
  id        String   @id @default("singleton")
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Singleton Google OAuth token, mirroring apps/web's GmailToken pattern.
model GoogleToken {
  id           String   @id @default("singleton")
  accessToken  String
  refreshToken String
  expiryDate   Float
  email        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CalendarEvent {
  id          String        @id // Google event id; recurring instances are unique with singleEvents=true
  title       String
  start       DateTime
  end         DateTime
  allDay      Boolean       @default(false)
  location    String?
  attendees   String? // JSON string [{name,email}]
  description String?
  source      String        @default("google")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  notes       MeetingNote[]

  @@index([start])
}

model MeetingNote {
  id                 String         @id // Granola note id (not_…)
  title              String
  summary            String
  attendees          String? // JSON string [{name,email}]
  calendarEventTitle String?
  calendarEventStart DateTime?
  noteUrl            String?
  raw                String? // full API payload
  granolaCreatedAt   DateTime?
  linkedEventId      String?
  linkedEvent        CalendarEvent? @relation(fields: [linkedEventId], references: [id])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([granolaCreatedAt])
}

model Todo {
  id        String    @id @default(cuid())
  text      String
  meta      String
  href      String?
  group     String
  status    String    @default("open") // open | cleared (today, undoable) | done (filed at end of day)
  clearedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
}

model ApolloTask {
  id           String    @id @default(cuid())
  ask          String
  status       String    @default("received") // received | working | done | failed
  planNote     String? // Apollo's one-line reading of the task
  stepsJson    String    @default("[]")
  resultJson   String? // briefing shape {title, dateline, sections[]}
  traceJson    String? // full messages array — the fine-tuning dataset
  model        String
  verdict      String? // good | needs-work
  feedbackNote String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([createdAt])
}

// Continual learning, prompt-side: distilled from reader feedback,
// injected into future Apollo system prompts.
model ApolloLesson {
  id        String   @id @default(cuid())
  taskId    String
  lesson    String
  createdAt DateTime @default(now())
}

// One row per local date — the daily job upserts, so re-runs are idempotent.
model BriefEdition {
  date         String   @id // YYYY-MM-DD in APP_TIMEZONE
  leadJson     String
  itemsJson    String
  scheduleJson String
  recallJson   String? // Worth Reciting cues drawn from yesterday's Margin
  generatedAt  DateTime @default(now())
}

// Freeform thinking filed below the news wire; the desk replies inline.
model MarginEntry {
  id        String   @id @default(cuid())
  text      String
  reply     String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// A reader-defined research theme, born from the intake interview.
model ResearchThesis {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  chip      String
  stance    String
  summary   String // paragraphs joined by \n\n
  charter   String // the built research prompt
  status    String   @default("active") // active | retired
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A thought filed to The File (/notes). First line is the title.
model FiledNote {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model BookContact {
  id           String   @id @default(cuid())
  name         String
  role         String
  firm         String
  segment      String // LPs | Founders | Co-investors | Advisors
  context      String
  relationship String?
  followUp     String?
  location     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
