# Anthropic — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google OAuth — create credentials at https://console.cloud.google.com
# Set redirect URI to: http://localhost:5820/api/auth/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App URL (use http://localhost:5820 for local dev)
NEXTAUTH_URL=http://localhost:5820

# Parallel — web research agent, required for monitor scan, founder search, and cold outbound
# Get yours at https://parallel.ai
PARALLEL_API_KEY=

# Turso — only needed for production (Vercel deployment)
# Get yours at https://turso.tech
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Vercel Blob — for document file uploads. Create a store at
# https://vercel.com/dashboard/stores and copy the read/write token.
BLOB_READ_WRITE_TOKEN=

# Voyage AI — for document embeddings (RAG). Get yours at https://voyageai.com
VOYAGE_API_KEY=

# Cron secret — shared bearer token for scheduled jobs (agents + morning report).
# Vercel Cron passes this automatically when set as a project env var.
CRON_SECRET=
