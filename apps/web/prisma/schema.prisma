generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Target {
  id            String          @id @default(cuid())
  name          String
  company       String
  email         String?
  linkedin      String?
  stage         String          @default("intro_sent")
  status        String          @default("yellow")
  lastContacted DateTime?
  notes         String?
  aiNextStep    String?
  industry      String?
  starred       Boolean         @default(false)
  starRank      Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  activities    Activity[]
  newsItems     NewsItem[]
  researchBrief ResearchBrief?
  outreachBrief OutreachBrief?
}

model GmailToken {
  id           String   @id @default("singleton")
  accessToken  String
  refreshToken String
  expiryDate   Float
  email        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Activity {
  id             String   @id @default(cuid())
  targetId       String
  type           String
  description    String
  date           DateTime @default(now())
  createdAt      DateTime @default(now())
  gmailMessageId String?
  target         Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
}

model NewsItem {
  id          String   @id @default(cuid())
  targetId    String
  headline    String
  url         String
  source      String
  summary     String   @default("")
  publishedAt DateTime
  createdAt   DateTime @default(now())
  target      Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
}

model Skill {
  id          String   @id @default(cuid())
  name        String
  description String
  prompt      String
  section     String   @default("targets")
  model       String   @default("claude-opus-4-6")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ResearchBrief {
  id          String   @id @default(cuid())
  targetId    String   @unique
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  target      Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
}

model Todo {
  id        String   @id @default(cuid())
  text      String
  completed Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentFolder {
  id        String        @id @default(cuid())
  name      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  links     ContentLink[]
}

model ContentLink {
  id          String         @id @default(cuid())
  title       String
  url         String
  description String?
  tag         String?
  folderId    String?
  folder      ContentFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model OutreachBrief {
  id           String   @id @default(cuid())
  targetId     String   @unique
  target       Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
  summary      String
  founders     String
  fundingStage String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
