generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Target {
  id              String          @id @default(cuid())
  name            String
  company         String
  email           String?
  linkedin        String?
  websiteUrl      String?
  founderName     String?
  founderFirstName String?
  founderLastName  String?
  stage           String          @default("intro_sent")
  status          String          @default("yellow")
  lastContacted   DateTime?
  notes           String?
  aiNextStep      String?
  industry        String?
  starred         Boolean         @default(false)
  starRank        Int?
  draftEmailSubject     String?
  draftEmailBody        String?
  draftEmailGeneratedAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  activities      Activity[]
  newsItems       NewsItem[]
  researchBrief   ResearchBrief?
  outreachBrief   OutreachBrief?
  founderReviews  FounderReview[]
  documents       Document[]
}

model FounderReview {
  id         String   @id @default(cuid())
  targetId   String
  candidates String   // JSON array of {output, confidence, run_id}
  status     String   @default("pending")  // pending | approved | denied
  createdAt  DateTime @default(now())
  target     Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
}

model GmailToken {
  id           String   @id @default("singleton")
  accessToken  String
  refreshToken String
  expiryDate   Float
  email        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Activity {
  id             String   @id @default(cuid())
  targetId       String
  type           String
  description    String
  date           DateTime @default(now())
  createdAt      DateTime @default(now())
  gmailMessageId String?
  target         Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
}

model NewsItem {
  id          String   @id @default(cuid())
  targetId    String
  headline    String
  url         String
  source      String
  summary     String   @default("")
  publishedAt DateTime
  createdAt   DateTime @default(now())
  target      Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
}

model Skill {
  id          String   @id @default(cuid())
  name        String
  description String
  prompt      String
  section     String   @default("targets")
  model       String   @default("claude-opus-4-6")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ResearchBrief {
  id          String   @id @default(cuid())
  targetId    String   @unique
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  target      Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
}

model Todo {
  id        String   @id @default(cuid())
  text      String
  completed Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentFolder {
  id        String        @id @default(cuid())
  name      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  links     ContentLink[]
}

model ContentLink {
  id          String         @id @default(cuid())
  title       String
  url         String
  description String?
  tag         String?
  folderId    String?
  folder      ContentFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model OutreachBrief {
  id           String   @id @default(cuid())
  targetId     String   @unique
  target       Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
  summary      String
  founders     String
  fundingStage String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model MonitorTheme {
  id            String       @id @default(cuid())
  name          String
  description   String
  keywords      String?
  enabled       Boolean      @default(true)
  lastScannedAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  hits          MonitorHit[]
}

model MonitorHit {
  id          String        @id @default(cuid())
  themeId     String
  companyName String
  url         String?
  description String
  matchReason String
  source      String
  sourceUrl   String?
  status      String        @default("pending")
  targetId    String?
  rawData     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  theme       MonitorTheme  @relation(fields: [themeId], references: [id], onDelete: Cascade)
}

model Agent {
  id              String     @id @default(cuid())
  name            String
  description     String     @default("")
  prompt          String
  triggerType     String     @default("manual")
  intervalSeconds Int?
  eventType       String?
  scope           String     @default("global")
  model           String     @default("claude-opus-4-6")
  enabled         Boolean    @default(true)
  lastRunAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  runs            AgentRun[]
}

model AgentRun {
  id        String   @id @default(cuid())
  agentId   String
  targetId  String?
  status    String   @default("success")
  output    String   @default("")
  trigger   String   @default("manual")
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Document {
  id        String          @id @default(cuid())
  title     String
  type      String          // "note" | "file" | "indexed"
  content   String?         // markdown body for notes; extracted text for indexed
  mimeType  String?
  fileUrl   String?         // Vercel Blob URL
  fileSize  Int?            // bytes
  targetId  String?
  target    Target?         @relation(fields: [targetId], references: [id], onDelete: SetNull)
  chunks    DocumentChunk[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String
  ordinal    Int
  // Voyage AI embedding stored as libSQL F32_BLOB. Vector index is created
  // out-of-band by scripts/setup-vector-index.ts since Prisma can't model it.
  embedding  Bytes?
  createdAt  DateTime @default(now())

  @@index([documentId, ordinal])
}
