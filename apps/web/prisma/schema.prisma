generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DATABASE_URL_UNPOOLED")
  extensions = [vector]
}

model Target {
  id              String          @id @default(cuid())
  name            String
  company         String
  email           String?
  linkedin        String?
  websiteUrl      String?
  founderName     String?
  founderFirstName String?
  founderLastName  String?
  stage           String          @default("intro_sent")
  status          String          @default("yellow")
  lastContacted   DateTime?
  notes           String?
  aiNextStep      String?
  industry        String?
  starred         Boolean         @default(false)
  starRank        Int?
  draftEmailSubject     String?
  draftEmailBody        String?
  draftEmailGeneratedAt DateTime?

  // Hermes additions
  embedding       Unsupported("vector(1024)")?
  synthesizedBlob String?         // text blob for embedding
  score           Float?          // algorithmic relevance score
  sourceType      String?         // linkedin_company, vc_website, techcrunch, etc.
  sourceUrl       String?         // originating URL
  ingestedAt      DateTime?       // first ingestion timestamp
  onChainAddress  String?         // token contract or wallet
  clusterId       String?         // FK to Cluster

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  activities      Activity[]
  newsItems       NewsItem[]
  researchBrief   ResearchBrief?
  outreachBrief   OutreachBrief?
  founderReviews  FounderReview[]
  documents       Document[]
  persons         Person[]
  fundingRounds   FundingRound[]
  cluster         Cluster?        @relation(fields: [clusterId], references: [id])

  @@index([sourceType])
  @@index([clusterId])
  @@index([score])
  @@index([ingestedAt])
}

model Person {
  id            String   @id @default(cuid())
  name          String
  currentRole   String?
  currentCompany String?
  careerHistory String?  // JSON array of {employer, role, years}
  linkedinUrl   String?
  twitterHandle String?
  email         String?
  bio           String?
  embedding     Unsupported("vector(1024)")?
  synthesizedBlob String?
  score         Float?
  sourceType    String?  // linkedin_founder, linkedin_mutuals, twitter_follower
  sourceUrl     String?
  targetId      String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  target        Target?  @relation(fields: [targetId], references: [id], onDelete: SetNull)

  @@index([targetId])
  @@index([sourceType])
}

model FundingRound {
  id            String   @id @default(cuid())
  targetId      String
  amount        String?  // e.g. "$25M"
  stage         String?  // seed, series_a, series_b, etc.
  date          DateTime?
  leadInvestor  String?
  coInvestors   String?  // JSON array of investor names
  sourceUrl     String?

  createdAt     DateTime @default(now())

  target        Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@index([targetId])
}

model Cluster {
  id              String   @id @default(cuid())
  label           String
  description     String?
  embedding       Unsupported("vector(1024)")?
  memberCount     Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  targets         Target[]
}

model HermesRun {
  id          String    @id @default(cuid())
  block       String    // ingestion, enrichment, embedding, clustering, entity_resolution, scoring, search, outreach
  status      String    // running, passed, failed
  steps       String    // JSON array of step events
  durationMs  Int?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
}

model FounderReview {
  id         String   @id @default(cuid())
  targetId   String
  candidates String
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  target     Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
}

model GmailToken {
  id           String   @id @default("singleton")
  accessToken  String
  refreshToken String
  expiryDate   Float
  email        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Activity {
  id             String   @id @default(cuid())
  targetId       String
  type           String
  description    String
  date           DateTime @default(now())
  createdAt      DateTime @default(now())
  gmailMessageId String?
  target         Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
}

model NewsItem {
  id          String   @id @default(cuid())
  targetId    String
  headline    String
  url         String
  source      String
  summary     String   @default("")
  publishedAt DateTime
  createdAt   DateTime @default(now())
  target      Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
}

model Skill {
  id          String   @id @default(cuid())
  name        String
  description String
  prompt      String
  section     String   @default("targets")
  model       String   @default("claude-opus-4-6")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ResearchBrief {
  id          String   @id @default(cuid())
  targetId    String   @unique
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  target      Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
}

model Todo {
  id        String   @id @default(cuid())
  text      String
  completed Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FocusTask {
  id          String    @id @default(cuid())
  text        String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    FocusTaskComment[]
}

model FocusTaskComment {
  id        String    @id @default(cuid())
  taskId    String
  text      String
  createdAt DateTime  @default(now())
  task      FocusTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Project {
  id        String           @id @default(cuid())
  name      String
  status    String           @default("idea")
  notes     String?
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  subtasks  ProjectSubtask[]
  links     ProjectLink[]
}

model ProjectSubtask {
  id        String   @id @default(cuid())
  projectId String
  text      String
  completed Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectLink {
  id        String   @id @default(cuid())
  projectId String
  url       String
  label     String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// People to recruit into Nazare, tracked through a hiring pipeline.
model Recruit {
  id        String        @id @default(cuid())
  name      String
  role      String? // role they'd fill at Nazare
  company   String? // where they are now
  email     String?
  linkedin  String?
  status    String        @default("prospect") // prospect | reached_out | in_conversation | interviewing | offer | joined | passed
  notes     String?
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  links     RecruitLink[]
}

model RecruitLink {
  id        String   @id @default(cuid())
  recruitId String
  url       String
  label     String?
  createdAt DateTime @default(now())
  recruit   Recruit  @relation(fields: [recruitId], references: [id], onDelete: Cascade)

  @@index([recruitId])
}

model ContentFolder {
  id        String        @id @default(cuid())
  name      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  links     ContentLink[]
}

model ContentLink {
  id          String         @id @default(cuid())
  title       String
  url         String
  description String?
  tag         String?
  folderId    String?
  folder      ContentFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model OutreachBrief {
  id           String   @id @default(cuid())
  targetId     String   @unique
  target       Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
  summary      String
  founders     String
  fundingStage String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ── Morning Report ─────────────────────────────────────────────
// A daily snapshot of every open item across To-Do's, Need to Do,
// and Project subtasks — triaged and (where possible) pre-drafted.

model MorningReport {
  id        String       @id @default(cuid())
  date      DateTime     @default(now())
  status    String       @default("generating") // generating | ready | failed
  summary   String       @default("") // AI "here's your day" blurb
  itemCount Int          @default(0)
  error     String?
  createdAt DateTime     @default(now())
  items     ReportItem[]

  @@index([date])
}

model ReportItem {
  id            String        @id @default(cuid())
  reportId      String
  report        MorningReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sourceType    String // todo | focus_task | project_subtask
  sourceId      String
  sourceText    String // snapshot of the item text at report time
  sourceContext String? // e.g. parent project name
  category      String        @default("manual") // email_reply | calendar | follow_up | manual
  priority      Int           @default(0) // higher = more urgent
  reasoning     String? // why it was categorized/prioritized this way
  createdAt     DateTime      @default(now())
  draft         ActionDraft?

  @@index([reportId])
}

model ActionDraft {
  id           String     @id @default(cuid())
  reportItemId String     @unique
  reportItem   ReportItem @relation(fields: [reportItemId], references: [id], onDelete: Cascade)
  type         String // email | calendar | follow_up

  // email / follow_up fields
  emailTo       String?
  emailThreadId String?
  emailSubject  String?
  emailBody     String?

  // calendar fields
  eventTitle       String?
  eventStart       DateTime?
  eventEnd         DateTime?
  eventAttendees   String? // JSON array of emails
  eventLocation    String?
  eventDescription String?

  // lifecycle / autonomy gate
  status          String    @default("pending") // pending | approved | executed | dismissed | failed
  autoExecuted    Boolean   @default(false)
  executedAt      DateTime?
  executionResult String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonitorTheme {
  id            String       @id @default(cuid())
  name          String
  description   String
  keywords      String?
  enabled       Boolean      @default(true)
  lastScannedAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  hits          MonitorHit[]
}

model MonitorHit {
  id           String        @id @default(cuid())
  themeId      String
  companyName  String
  url          String?
  description  String
  matchReason  String
  source       String
  sourceUrl    String?
  status       String        @default("pending")
  targetId     String?
  rawData      String?
  autoPromoted Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  theme        MonitorTheme  @relation(fields: [themeId], references: [id], onDelete: Cascade)
}

model Agent {
  id              String     @id @default(cuid())
  name            String
  description     String     @default("")
  prompt          String
  triggerType     String     @default("manual")
  intervalSeconds Int?
  eventType       String?
  scope           String     @default("global")
  model           String     @default("claude-opus-4-6")
  enabled         Boolean    @default(true)
  lastRunAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  runs            AgentRun[]
}

model AgentRun {
  id        String   @id @default(cuid())
  agentId   String
  targetId  String?
  status    String   @default("success")
  output    String   @default("")
  trigger   String   @default("manual")
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Document {
  id        String          @id @default(cuid())
  title     String
  type      String          // "note" | "file" | "indexed"
  content   String?         // markdown body for notes; extracted text for indexed
  mimeType  String?
  fileUrl   String?         // Vercel Blob URL
  fileSize  Int?            // bytes
  targetId  String?
  target    Target?         @relation(fields: [targetId], references: [id], onDelete: SetNull)
  chunks    DocumentChunk[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String
  ordinal    Int
  // Voyage AI embedding stored as libSQL F32_BLOB. Vector index is created
  // out-of-band by scripts/setup-vector-index.ts since Prisma can't model it.
  embedding  Bytes?
  createdAt  DateTime @default(now())

  @@index([documentId, ordinal])
}
